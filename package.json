{
  "name": "web-archive",
  "version": "1.7.2",
  "description": "",
  "private": true,
  "workspaces": [
    "packages/shared",
    "server",
    "ui"
  ],
  "type": "module",
  "main": "index.js",
  "scripts": {
    "scrape": "node index.js",
    "build:server": "npm run build --workspace=server",
    "build:ui": "npm run build --workspace=ui",
    "build": "npm run build --workspace=packages/shared && npm run build:server && npm run build:ui && npm prune --omit=dev && docker build --build-arg BRANCH=$(git rev-parse --abbrev-ref HEAD) --build-arg COMMIT=$(git rev-parse --short HEAD) -t web-archive:local . && npm install",
    "test": "npm run test --workspaces --if-present"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@tkottke/node-utils": "github:tkottke90/nodejs-utils#v2.1.3",
    "inquirer": "^9.2.11",
    "lodash": "^4.17.21",
    "lucide-preact": "^0.475.0",
    "mime-types": "^2.1.35",
    "node-fetch": "^3.3.1"
  },
  "devDependencies": {
    "@types/multer": "^1.4.9",
    "changelog": "^1.4.2"
  }
}
