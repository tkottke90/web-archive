{
  "name": "web-storage",
  "version": "0.0.0",
  "description": "Web application to store content I find on the web that I want to keep in a standardized way",
  "main": "index.js",
  "scripts": {
    "build": "prisma generate && tsc",
    "generate": "prisma generate",
    "format": "prettier --config .prettierrc 'src/**/*.ts' --write",
    "test": "nyc mocha",
    "scan": "sonar-scanner",
    "lint": "eslint --fix src/**/*",
    "cicd-lint": "eslint src/**/* --format json --output-file eslint-report.json",
    "purge": "rm -rf uploads/*",
    "start": "nodemon",
    "changelog-patch": "changelog -p",
    "changelog-minor": "changelog -m",
    "changelog-major": "changelog -M"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@web-archive/shared": "*",
    "@decorators/di": "2.0.0",
    "@decorators/express": "2.9.1",
    "@prisma/client": "^5.9.1",
    "@tkottke/hateos-url-manager": "github:tkottke90/javscript-hateos-router#v1.1.0",
    "dotenv": "16.0.1",
    "express": "4.18.1",
    "jsdom": "22.1.0",
    "mime-types": "2.1.35",
    "multer": "1.4.5-lts.1",
    "node-cron": "3.0.3",
    "prisma": "^5.9.1",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@types/chai": "^4.3.20",
    "@types/express": "4.17.13",
    "@types/jsdom": "^21.1.5",
    "@types/mime-types": "^2.1.4",
    "@types/mocha": "^10.0.10",
    "@types/multer": "1.4.7",
    "@types/node": "18.7.6",
    "@types/node-cron": "^3.0.11",
    "@types/sinon": "^17.0.3",
    "@typescript-eslint/eslint-plugin": "5.33.1",
    "@typescript-eslint/parser": "5.33.1",
    "chai": "^4.5.0",
    "eslint": "8.22.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-unused-imports": "^2.0.0",
    "generate-changelog": "^1.8.0",
    "mocha": "^10.8.2",
    "nodemon": "2.0.19",
    "nyc": "^18.0.0",
    "prettier": "^2.7.1",
    "reflect-metadata": "0.1.13",
    "sinon": "^17.0.2",
    "sonarqube-scanner": "^4.0.1",
    "source-map-support": "^0.5.21",
    "ts-node": "10.9.1",
    "tsconfig-paths": "4.1.0",
    "typescript": "4.7.4"
  },
  "eslintConfig": {
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended",
      "plugin:prettier/recommended"
    ],
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint",
      "unused-imports"
    ],
    "root": true,
    "rules": {
      "quotes": [
        "error",
        "single"
      ],
      "no-debugger": "error",
      "unused-imports/no-unused-imports": "error",
      "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }]
    }
  },
  "nyc": {
    "extends": "@istanbuljs/nyc-config-typescript",
    "all": true,
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "src/**/*.spec.ts",
      "src/test/**"
    ],
    "reporter": [
      "text",
      "lcov"
    ],
    "report-dir": "coverage"
  }
}
